{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "change-this-gateway-token"
    }
  },
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": true,
      "allow": ["producer", "concept", "conversation", "builder", "compliance"]
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "session": {
    "agentToAgent": {
      "maxPingPongTurns": 3
    }
  },
  "cron": {
    "enabled": true,
    "sessionRetention": "24h"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4o"
      }
    },
    "list": [
      {
        "id": "producer",
        "name": "Producer",
        "default": true,
        "workspace": "/opt/chatbizos/.openclaw/workspaces/producer",
        "agentDir": "/opt/chatbizos/.openclaw/agents/producer/agent",
        "model": "openai/gpt-4o",
        "identity": {
          "name": "Producer"
        }
      },
      {
        "id": "concept",
        "name": "Concept",
        "workspace": "/opt/chatbizos/.openclaw/workspaces/concept",
        "agentDir": "/opt/chatbizos/.openclaw/agents/concept/agent",
        "model": "openai/gpt-4o",
        "identity": {
          "name": "Concept"
        }
      },
      {
        "id": "conversation",
        "name": "Conversation",
        "workspace": "/opt/chatbizos/.openclaw/workspaces/conversation",
        "agentDir": "/opt/chatbizos/.openclaw/agents/conversation/agent",
        "model": "openai/gpt-4o",
        "identity": {
          "name": "Conversation"
        }
      },
      {
        "id": "builder",
        "name": "Builder",
        "workspace": "/opt/chatbizos/.openclaw/workspaces/builder",
        "agentDir": "/opt/chatbizos/.openclaw/agents/builder/agent",
        "model": "openai/gpt-4o",
        "identity": {
          "name": "Builder"
        }
      },
      {
        "id": "compliance",
        "name": "Compliance",
        "workspace": "/opt/chatbizos/.openclaw/workspaces/compliance",
        "agentDir": "/opt/chatbizos/.openclaw/agents/compliance/agent",
        "model": "openai/gpt-4o",
        "identity": {
          "name": "Compliance"
        }
      }
    ]
  },
  "channels": {
    "defaults": {
      "groupPolicy": "allowlist"
    },
    "discord": {
      "enabled": true,
      "token": "your-discord-bot-token",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "historyLimit": 20,
      "threadBindings": {
        "enabled": true,
        "idleHours": 24,
        "maxAgeHours": 0,
        "spawnSubagentSessions": true
      },
      "guilds": {
        "your-discord-guild-id": {
          "requireMention": false,
          "channels": {
            "your-discord-channel-id": {
              "allow": true,
              "requireMention": false
            }
          }
        }
      }
    },
    "slack": {
      "enabled": false,
      "botToken": "xoxb-your-slack-bot-token",
      "appToken": "xapp-your-slack-app-token",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "historyLimit": 50,
      "channels": {
        "your-slack-channel-id": {
          "allow": true,
          "requireMention": false,
          "allowBots": false
        }
      }
    }
  }
}
